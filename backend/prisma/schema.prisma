generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(cuid())
  nickname      String
  email         String?  @unique
  emailVerified Boolean  @default(false)
  phone         String?
  marketingOk   Boolean  @default(false)
  createdAt     DateTime @default(now())
  sessionToken  String?  @unique

  bookings      Booking[]
  votes         Vote[]
  comments      Comment[]
  performances  Performance[]
  hostedEvents  Event[]       @relation("EventHost")
  leaderboard   Leaderboard?
}

model OtpCode {
  id        String   @id @default(cuid())
  email     String
  code      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

model Event {
  id               String      @id @default(cuid())
  name             String
  location         String
  date             DateTime
  status           EventStatus @default(DRAFT)
  joinCode         String      @unique
  hostId           String
  createdAt        DateTime    @default(now())
  /** Banco GM per playback MIDI (fluid_r3 | musyng_kite | fatboy). */
  soundfontBankId  String      @default("fluid_r3")
  /** Admin (o superadmin) che gestisce la serata. */
  adminId          String?

  host        User          @relation("EventHost", fields: [hostId], references: [id])
  admin       AdminUser?    @relation(fields: [adminId], references: [id])
  bookings    Booking[]
  performances Performance[]
}

/** Account del pannello host: il superadmin gestisce anche il server e gli altri admin. */
model AdminUser {
  id           String    @id @default(cuid())
  username     String    @unique
  passwordHash String
  role         AdminRole @default(ADMIN)
  createdAt    DateTime  @default(now())

  events Event[]
  songs  Song[]
}

enum AdminRole {
  SUPERADMIN
  ADMIN
}

enum EventStatus {
  DRAFT
  OPEN
  LIVE
  ENDED
}

model Song {
  id        String     @id @default(cuid())
  title     String
  artist    String
  source    SongSource
  midiPath  String?
  lrcPath   String?
  mp3Path   String?
  duration  Int?
  language  String?
  tags      String[]
  createdAt DateTime   @default(now())
  /** Proprietario del catalogo: visibile a tutte le sue serate, non agli altri admin. */
  adminId   String?
  /** Traccia MIDI da silenziare in riproduzione (voce guida, di solito la 4). 1-based. */
  mutedTrack Int?
  /** Trasposizione globale in semitoni (-12…+12). Vale per tutte le esecuzioni del brano. */
  transposeSemitones Int @default(0)
  /** Nome del file originale caricato, con estensione (es. "Albachiara.kar"). */
  fileName  String?
  /** Anno del brano (di solito dal meta-evento copyright del MIDI). */
  year      Int?
  /** Genere musicale (lookup online o inserito a mano). */
  genre     String?
  /** Copertina (URL esterno, di solito da iTunes Search al caricamento). */
  coverUrl  String?

  admin    AdminUser? @relation(fields: [adminId], references: [id])
  bookings Booking[]
}

enum SongSource {
  MIDI
  YOUTUBE
}

model Booking {
  id         String        @id @default(cuid())
  eventId    String
  userId     String
  songId     String?
  ytUrl      String?
  ytTitle    String?
  ytLrcFound Boolean?
  ytProcessError String?
  position   Int
  status     BookingStatus @default(PENDING)
  adminNote  String?
  createdAt  DateTime      @default(now())

  event       Event        @relation(fields: [eventId], references: [id])
  user        User         @relation(fields: [userId], references: [id])
  song        Song?        @relation(fields: [songId], references: [id])
  performance Performance?
}

enum BookingStatus {
  PENDING
  APPROVED
  PROCESSING
  READY
  PERFORMING
  DONE
  SKIPPED
  REJECTED
}

model Performance {
  id             String    @id @default(cuid())
  eventId        String
  bookingId      String    @unique
  userId         String
  startedAt      DateTime?
  endedAt        DateTime?
  scoreTotal     Float?
  votesAvg       Float?
  commentsCount  Int       @default(0)
  bonusEngagement Float?
  createdAt      DateTime  @default(now())

  event       Event     @relation(fields: [eventId], references: [id])
  booking     Booking   @relation(fields: [bookingId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  votes       Vote[]
  comments    Comment[]
}

model Vote {
  id            String   @id @default(cuid())
  performanceId String
  userId        String
  value         Int
  createdAt     DateTime @default(now())

  performance Performance @relation(fields: [performanceId], references: [id])
  user        User        @relation(fields: [userId], references: [id])

  @@unique([performanceId, userId])
}

model Comment {
  id            String   @id @default(cuid())
  performanceId String
  userId        String
  text          String   @db.VarChar(120)
  emoji         String?
  createdAt     DateTime @default(now())

  performance Performance @relation(fields: [performanceId], references: [id])
  user        User        @relation(fields: [userId], references: [id])
}

model Leaderboard {
  userId       String   @id
  totalScore   Float    @default(0)
  performances Int      @default(0)
  bestScore    Float?
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}
