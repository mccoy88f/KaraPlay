JWT_SECRET=genera-una-stringa-lunga-e-casuale

# Token per le route /api/admin/* (pannello host). Docker Compose: se OMETTI questa riga, il default è
# dev-admin-token. Se COPI questa riga da esempio, devi usare LO STESSO valore nel campo admin del browser.
# ADMIN_TOKEN=dev-admin-token

DATABASE_URL=postgresql://karaoke:password@localhost:5432/karaokedb
REDIS_URL=redis://localhost:6379

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@tuodominio.it

# Frontend build (opzionale: URL assoluto API se non usi proxy /api)
VITE_API_URL=

# File cookies Netscape per yt-dlp (montaggio volume). Alternativa: upload da /admin (API)
YOUTUBE_COOKIES_PATH=
